    {
      "host": "metal3-mcp.devpod",
      "args": [],
      "projects": [],
    },
    {
      "host": "workspace.devpod",
      "args": [],
      "projects": [],
    },
    {
      "host": "10.1.0.84",
      "username": "ubuntu",
      "args": ["-J", "xerces-capo"],
      "projects": [
        {
          "paths": ["/home/ubuntu/workspace"],
        },
      ],
    },
    {
      "host": "lennart-capo-upgrade",
      "username": "ubuntu",
      "args": [],
      "projects": [
        {
          "paths": ["/home/ubuntu/dotfiles"],
        },
      ],
