  "ui_font_size": 16,
  "buffer_font_size": 16,
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "One Dark",
  },
  "tab_size": 2,
  "minimap": {
    "show": "always",
  },
  "agent": {
    "tool_permissions": {
      "default": "allow",
    },
    "profiles": {
      "minimal-write": {
        "name": "Minimal write",
        "tools": {
          "copy_path": true,
          "create_directory": true,
          "delete_path": true,
          "diagnostics": true,
          "edit_file": true,
          "fetch": true,
          "list_directory": true,
          "project_notifications": false,
          "move_path": true,
          "now": true,
          "find_path": true,
          "read_file": true,
          "restore_file_from_disk": true,
          "save_file": true,
          "open": true,
          "grep": true,
          "spawn_agent": true,
          "terminal": true,
          "thinking": true,
          "web_search": true,
        },
        "enable_all_context_servers": true,
        "context_servers": {
          "github-mcp": {
            "tools": {
              "update_pull_request_branch": false,
              "update_pull_request": false,
              "sub_issue_write": false,
              "request_copilot_review": false,
              "push_files": false,
              "pull_request_review_write": false,
              "merge_pull_request": false,
              "issue_write": false,
              "fork_repository": false,
              "delete_file": false,
              "create_repository": false,
              "create_pull_request": false,
              "create_or_update_file": false,
              "create_branch": false,
              "assign_copilot_to_issue": false,
              "add_reply_to_pull_request_comment": false,
              "add_issue_comment": false,
              "add_comment_to_pending_review": false,
            },
          },
        },
      },
      "write": {
        "name": "Write",
        "tools": {
          "copy_path": true,
          "create_directory": true,
          "delete_path": true,
          "diagnostics": true,
          "edit_file": true,
          "fetch": true,
          "list_directory": true,
          "project_notifications": false,
          "move_path": true,
          "now": true,
          "find_path": true,
          "read_file": true,
          "restore_file_from_disk": true,
          "save_file": true,
          "open": true,
          "grep": true,
          "spawn_agent": true,
          "terminal": true,
          "thinking": true,
          "web_search": true,
        },
        "enable_all_context_servers": true,
        "context_servers": {},
      },
      "ask": {
        "name": "Ask",
        "tools": {
          "contents": true,
          "diagnostics": true,
          "fetch": true,
          "list_directory": true,
          "project_notifications": false,
          "now": true,
          "find_path": true,
          "read_file": true,
          "open": true,
          "grep": true,
          "thinking": true,
          "web_search": true,
        },
        "enable_all_context_servers": false,
        "context_servers": {
          "github-mcp": {
            "tools": {
              "search_users": true,
              "search_repositories": true,
              "search_pull_requests": true,
              "search_orgs": true,
              "search_issues": true,
              "search_code": true,
              "actions_list": true,
              "actions_get": true,
              "list_tags": true,
              "list_releases": true,
              "list_secret_scanning_alerts": true,
              "list_pull_requests": true,
              "list_notifications": true,
              "list_issues": true,
              "list_gists": true,
              "list_discussions": true,
              "list_discussion_categories": true,
              "list_dependabot_alerts": true,
              "list_commits": true,
              "list_code_scanning_alerts": true,
              "list_branches": true,
              "get_tag": true,
              "get_latest_release": true,
              "get_release_by_tag": true,
              "get_secret_scanning_alert": true,
              "pull_request_read": true,
              "get_notification_details": true,
              "get_me": true,
              "get_teams": true,
              "get_team_members": true,
              "get_job_logs": true,
              "issue_read": true,
              "get_file_contents": true,
              "get_repository_tree": true,
              "get_discussion_comments": true,
              "get_discussion": true,
              "get_dependabot_alert": true,
              "get_code_scanning_alert": true,
              "get_commit": true,
              "get_gist": true,
              "get_label": true,
            },
          },
        },
      },
    },
    "default_profile": "minimal-write",
    "default_model": {
      "effort": "high",
      "enable_thinking": true,
      "provider": "copilot_chat",
      "model": "claude-sonnet-4.6",
    },
    "commit_message_model": {
      "provider": "copilot_chat",
      "model": "claude-haiku-4.5",
    },
  },
  "language_models": {
    "ollama": {
      "context_window": 40000,
      "api_url": "http://192.168.122.108:11434",
    },
  },
  "languages": {
    "Markdown": {
      "soft_wrap": "editor_width",
    },
    "YAML": {
      "prettier": {
        "allowed": false,
      },
      "formatter": {
        "external": {
          "command": "yamlfmt",
          "arguments": ["-in"],
        },
      },
    },
  },
  "lsp": {
    "gopls": {
      "initialization_options": {
        "buildFlags": ["-tags=e2e,tools"],
      },
    },
    "yaml-language-server": {
      "settings": {
        "yaml": {
          "schemaStore": {
            "enable": false,
          },
        },
      },
    },
  },
}
