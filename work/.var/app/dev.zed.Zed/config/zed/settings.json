// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "git_panel": {
    "tree_view": true,
  },
  "agent_servers": {
    "github-copilot-cli": {
      "type": "registry",
    },
    "opencode": {
      "type": "registry",
    },
    "github-copilot": {
      "type": "registry",
    },
  },
  "edit_predictions": {
    "provider": "copilot",
  },
  "terminal": {
    "dock": "bottom",
    "env": {
      "LD_LIBRARY_PATH": "",
      "LD_PRELOAD": "",
    },
  },
  "context_servers": {
    "github-mcp": {
      "command": "github-mcp.sh",
      "args": [],
    },
  },
  "ssh_connections": [
    {
      "host": "capo.devpod",
      "args": [],
      "projects": [
        {
          "paths": ["/workspaces/capo"],
        },
      ],
    },
    {
      "host": "capi.devpod",
      "args": [],
      "projects": [
        {
          "paths": ["/workspaces/capi"],
        },
      ],
    },
