// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "project_panel": {
    "dock": "right",
  },
  "outline_panel": {
    "dock": "left",
  },
  "collaboration_panel": {
    "dock": "left",
  },
  "git_panel": {
    "dock": "right",
  },
  "edit_predictions": {
    "provider": "copilot",
  },
  "terminal": {
    "dock": "bottom",
    "env": {
      "LD_LIBRARY_PATH": "",
      "LD_PRELOAD": "",
    },
  },
  "icon_theme": "Zed (Default)",
  "context_servers": {
    "github-mcp": {
      "command": "github-mcp.sh",
      "args": [],
    },
  },
  "agent": {
    "dock": "left",
    "tool_permissions": {
      "tools": {
        "terminal": {
          "default": "allow",
        },
        "mcp:github-mcp:pull_request_read": {
          "default": "allow",
        },
      },
    },
    "default_model": {
      "effort": "high",
      "enable_thinking": true,
      "provider": "copilot_chat",
      "model": "claude-opus-4.6",
    },
    "model_parameters": [],
    "inline_assistant_model": {
      "provider": "copilot_chat",
      "model": "claude-4.6-sonnet",
    },
  },
  "ui_font_size": 16,
  "buffer_font_size": 16,
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "One Dark",
  },
  "minimap": {
    "show": "always",
  },
  "languages": {
    "YAML": {
      "prettier": {
        "allowed": false,
      },
      "formatter": {
        "external": {
          "command": "yamlfmt",
          "arguments": ["-in"],
        },
      },
    },
  },
}
